{
    "extends": [
        "eslint:recommended",
        "plugin:react/recommended",
        "plugin:@typescript-eslint/recommended",
        "plugin:import/errors",
        "plugin:import/warnings",
        "prettier/@typescript-eslint",
    ],
    "plugins": [
        "react",
        "@typescript-eslint",
        "prettier",
        "jsx-a11y",
        "flowtype"
    ],
    "env": {
        "browser": true,
        "jasmine": true,
        "jest": true
    },
    "settings": {
        "react": {
            "pragma": "React",
            "version": "detect"
        }
    },
    "parser": "@typescript-eslint/parser"
}